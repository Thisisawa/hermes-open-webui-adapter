# Hermes Tool Filter Configuration

# Tool display mode:
#   passthrough - direct pass-through of <details> tags (default, safest)
#   enhance     - inject done=true + arguments on completion (recommended)
#   strip       - remove <details> and replace with plain text (legacy)
TOOL_MODE=passthrough

# Auto-split threshold (characters), 0 = disabled
# Note: Conduit APP does not support session.split events
AUTO_SPLIT_THRESHOLD=0
